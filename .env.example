# =============================================================================
# MedLingo Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Required: Directory where trained model weights are stored/saved.
# All component paths (bridges, router, specialists, adjudicator) are
# resolved as subdirectories of this root.
# ---------------------------------------------------------------------------
MEDLINGO_WEIGHTS_DIR=/path/to/your/weights

# ---------------------------------------------------------------------------
# Required for downloading gated HuggingFace models (Llama, BioMedCLIP).
# Generate at: https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Optional: Override the HuggingFace model cache directory.
# Defaults to ~/.cache/medlingo if not set.
# ---------------------------------------------------------------------------
# MEDLINGO_CACHE_DIR=/fast-nvme/.cache/medlingo

# ---------------------------------------------------------------------------
# Optional: Weights & Biases experiment tracking.
# ---------------------------------------------------------------------------
# WANDB_API_KEY=your_wandb_api_key
# WANDB_PROJECT=medlingo-training
# WANDB_ENTITY=your_team_name
